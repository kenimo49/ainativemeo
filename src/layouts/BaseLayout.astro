---
interface Props {
  title: string;
  description: string;
  lang: 'en' | 'ja';
  ogUrl: string;
  noindex?: boolean;
}

const { title, description, lang, ogUrl, noindex = false } = Astro.props;
const siteUrl = 'https://ainativemeo.com';
const ogImage = `${siteUrl}/og-default.png`;
const gaId = import.meta.env.PUBLIC_GA_ID ?? 'G-Z8XXW9S0D8';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <title>{title}</title>
    <link rel="canonical" href={ogUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    {gaId && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script is:inline define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </>
    )}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <style>
      @import "tailwindcss";

      :root {
        --color-bg: #0a0e1a;
        --color-bg-card: #131826;
        --color-text: #e6edf3;
        --color-text-muted: #8b95a7;
        --color-accent: #6366f1;
        --color-accent-hover: #818cf8;
        --color-border: #1f2937;
      }

      html {
        background: var(--color-bg);
        color: var(--color-text);
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Hiragino Kaku Gothic ProN", "Hiragino Sans", Meiryo, sans-serif;
        -webkit-font-smoothing: antialiased;
      }

      body {
        background: var(--color-bg);
        color: var(--color-text);
        margin: 0;
        min-height: 100vh;
      }

      a {
        color: var(--color-accent);
        text-decoration: none;
      }

      a:hover {
        color: var(--color-accent-hover);
        text-decoration: underline;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
