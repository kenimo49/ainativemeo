---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import type { Alternate } from '../lib/alternates';

interface SlideImage {
  src: string;
  alt: string;
  photographer?: string;
  photographer_url?: string;
  source?: string;
}

interface Props {
  title: string;
  description: string;
  lang: 'en' | 'ja';
  date: Date;
  updated?: Date;
  category?: 'framework' | 'engineering' | 'comparison';
  tags: string[];
  canonicalUrl: string;
  ogImage?: string;
  alternates?: Alternate[];
  images?: SlideImage[];
}

const { title, description, lang, date, updated, category, tags, canonicalUrl, ogImage, alternates = [], images = [] } = Astro.props;
const formattedDate = date.toISOString().split('T')[0];
const siteUrl = 'https://ainativemeo.com';
const blogIndexUrl = lang === 'ja' ? '/ja/blog/' : '/blog/';

const categoryLabel = (cat?: string) => {
  if (!cat) return '';
  const labels: Record<string, { en: string; ja: string }> = {
    framework: { en: 'Framework', ja: 'フレームワーク' },
    engineering: { en: 'Engineering', ja: 'エンジニアリング' },
    comparison: { en: 'Comparison', ja: '比較' },
  };
  return labels[cat]?.[lang === 'ja' ? 'ja' : 'en'] || cat;
};

const toRoman = (n: number) => {
  const numerals = ['I', 'II', 'III', 'IV', 'V', 'VI', 'VII', 'VIII', 'IX', 'X'];
  return numerals[n - 1] || String(n);
};

const blogPostingJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  image: ogImage
    ? (ogImage.startsWith('http') ? ogImage : new URL(ogImage, siteUrl).href)
    : `${siteUrl}/og-default.png`,
  datePublished: date.toISOString(),
  dateModified: (updated ?? date).toISOString(),
  author: {
    '@type': 'Person',
    '@id': 'https://kenimoto.dev/#person',
    name: 'Ken Imoto',
    url: 'https://kenimoto.dev/',
    sameAs: [
      'https://kenimoto.dev/',
      'https://github.com/kenimo49',
    ],
    worksFor: {
      '@type': 'Organization',
      name: 'Propel-Lab LLC',
      url: 'https://propel-lab.co.jp/',
    },
  },
  publisher: {
    '@type': 'Organization',
    '@id': `${siteUrl}/#organization`,
    name: 'AI Native MEO',
    url: `${siteUrl}/`,
  },
  url: canonicalUrl,
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
  ...(tags && tags.length > 0 ? { keywords: tags.join(', ') } : {}),
  ...(category ? { articleSection: categoryLabel(category) } : {}),
  inLanguage: lang === 'ja' ? 'ja-JP' : 'en-US',
  isBasedOn: {
    '@type': 'CreativeWork',
    name: 'LLMO Framework',
    url: 'https://llmoframework.com/',
  },
};

const homeUrl = lang === 'ja' ? `${siteUrl}/ja/` : `${siteUrl}/`;
const blogUrl = lang === 'ja' ? `${siteUrl}/ja/blog/` : `${siteUrl}/blog/`;
const breadcrumbItems = [
  { name: lang === 'ja' ? 'ホーム' : 'Home', url: homeUrl },
  { name: lang === 'ja' ? '記事' : 'Articles', url: blogUrl },
  { name: title, url: canonicalUrl },
];
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbItems.map((item, idx) => ({
    '@type': 'ListItem',
    position: idx + 1,
    name: item.name,
    item: item.url,
  })),
};
---

<BaseLayout
  title={title}
  description={description}
  lang={lang}
  ogUrl={canonicalUrl}
>
  <Nav lang={lang} />

  <article class="article-shell">
    <header class="article-header">
      <div class="article-meta">
        {category && (
          <span class={`category-pill cat-${category}`}>{categoryLabel(category)}</span>
        )}
        <time class="article-date" datetime={formattedDate}>{formattedDate}</time>
      </div>
      <h1 class="article-title">{title}</h1>
      <p class="article-lede">{description}</p>
      <div class="article-rule" aria-hidden="true"></div>
    </header>

    {images && images.length > 0 && (
      <section class="plate-gallery" aria-label={lang === 'ja' ? '挿図' : 'Plates'}>
        {images.map((img, idx) => (
          <figure class="plate">
            <div class="plate-frame">
              <img src={img.src} alt={img.alt} loading="lazy" width="900" height="600" />
            </div>
            <figcaption>
              <span class="plate-number">{lang === 'ja' ? `図 ${toRoman(idx + 1)}` : `Plate ${toRoman(idx + 1)}`}</span>
              <span class="plate-alt">{img.alt}</span>
              {img.photographer && (
                <span class="plate-credit">
                  {lang === 'ja' ? '撮影: ' : 'Photograph: '}
                  {img.photographer_url ? (
                    <a href={img.photographer_url} rel="noopener noreferrer" target="_blank">{img.photographer}</a>
                  ) : (
                    <span>{img.photographer}</span>
                  )}
                  {img.source && (
                    <span class="plate-source"> · {img.source}</span>
                  )}
                </span>
              )}
            </figcaption>
          </figure>
        ))}
      </section>
    )}

    <div class="prose-content">
      <slot />
    </div>

    <footer class="article-footer">
      <div class="ornament" aria-hidden="true">§ &nbsp; § &nbsp; §</div>
      <p class="colophon">
        AI Native MEO is built on the
        <a href="https://llmoframework.com/">LLMO Framework</a>.
        Part of <a href="https://kenimoto.dev/">Ken Imoto</a>'s research and publication ecosystem.
      </p>
      <p class="back-link">
        <a href={blogIndexUrl}>
          {lang === 'ja' ? '← 記事一覧に戻る' : '← Back to articles'}
        </a>
      </p>
    </footer>
  </article>

  <script type="application/ld+json" set:html={JSON.stringify(blogPostingJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

  <style>
    .article-shell {
      max-width: 44rem;
      margin: 0 auto;
      padding: 3rem 1.5rem 4rem;
    }
    .article-header {
      margin-bottom: 2.5rem;
    }
    .article-meta {
      display: flex;
      align-items: baseline;
      gap: 1rem;
      margin-bottom: 1.25rem;
      font-family: var(--font-smallcaps);
      font-variant-caps: all-small-caps;
      letter-spacing: 0.14em;
      font-size: 0.95rem;
    }
    .category-pill {
      color: var(--color-green-civic);
      font-weight: 500;
    }
    .cat-engineering { color: var(--color-green-civic); }
    .cat-framework { color: var(--color-red-civic); }
    .cat-comparison { color: var(--color-ink-soft); }
    .article-date {
      color: var(--color-text-muted);
      font-family: var(--font-mono);
      font-variant-caps: normal;
      letter-spacing: 0;
      font-size: 0.85rem;
    }
    .article-title {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: clamp(2.1rem, 4.2vw, 3.1rem);
      line-height: 1.08;
      letter-spacing: -0.02em;
      margin: 0 0 1.1rem 0;
      color: var(--color-ink);
    }
    .article-lede {
      font-family: var(--font-display);
      font-style: italic;
      font-weight: 400;
      font-size: 1.25rem;
      line-height: 1.55;
      color: var(--color-ink-soft);
      margin: 0 0 1.5rem 0;
    }
    .article-rule {
      border-bottom: 2px solid var(--color-ink);
      position: relative;
      margin-top: 1.5rem;
    }
    .article-rule::after {
      content: "";
      position: absolute;
      left: 0;
      bottom: -5px;
      width: 100%;
      border-bottom: 1px solid var(--color-ink);
    }

    /* plate gallery — almanac plate feel */
    .plate-gallery {
      display: grid;
      gap: 2.25rem;
      margin: 2.5rem 0 3rem;
    }
    .plate {
      margin: 0;
    }
    .plate-frame {
      padding: 0.55rem;
      background: var(--color-paper-deep);
      border: 1px solid var(--color-rule);
      box-shadow:
        0 1px 0 var(--color-rule-soft),
        0 0 0 4px var(--color-paper),
        0 0 0 5px var(--color-rule);
    }
    .plate-frame img {
      display: block;
      width: 100%;
      height: auto;
      aspect-ratio: 3 / 2;
      object-fit: cover;
      /* warm-paper photo treatment: gentle sepia + slight desat + soft contrast */
      filter: sepia(0.14) saturate(0.82) contrast(0.94) brightness(0.98);
    }
    .plate figcaption {
      margin-top: 0.85rem;
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
      font-size: 0.92rem;
      line-height: 1.45;
      color: var(--color-ink-soft);
      text-align: center;
    }
    .plate-number {
      font-family: var(--font-smallcaps);
      font-variant-caps: all-small-caps;
      letter-spacing: 0.18em;
      color: var(--color-red-civic);
      font-weight: 500;
    }
    .plate-alt {
      font-family: var(--font-display);
      font-style: italic;
      font-size: 0.95rem;
      color: var(--color-ink-soft);
    }
    .plate-credit {
      font-size: 0.78rem;
      color: var(--color-text-muted);
      font-family: var(--font-body);
    }
    .plate-credit a {
      color: var(--color-text-muted);
      text-decoration-color: rgba(107, 99, 88, 0.45);
    }
    .plate-credit a:hover {
      color: var(--color-red-civic);
    }
    .plate-source {
      opacity: 0.75;
    }

    .article-footer {
      margin-top: 4rem;
    }
    .ornament {
      text-align: center;
      color: var(--color-rule);
      font-family: var(--font-display);
      letter-spacing: 0.5em;
      font-size: 1rem;
      margin: 0 0 2rem;
    }
    .colophon {
      font-family: var(--font-display);
      font-style: italic;
      font-size: 0.95rem;
      color: var(--color-ink-soft);
      text-align: center;
      margin: 0 0 1rem;
      line-height: 1.6;
    }
    .back-link {
      text-align: center;
      font-family: var(--font-smallcaps);
      font-variant-caps: all-small-caps;
      letter-spacing: 0.14em;
      font-size: 0.95rem;
      margin: 0;
    }
    .back-link a {
      text-decoration: none;
      color: var(--color-green-civic);
    }
  </style>

  <style is:global>
    .prose-content {
      color: var(--color-ink);
      font-family: var(--font-body);
      font-size: 1.07rem;
      line-height: 1.75;
      font-feature-settings: "kern" 1, "liga" 1, "onum" 1;
    }
    /* drop cap on the very first paragraph of the article */
    .prose-content > p:first-of-type::first-letter {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 4.4rem;
      line-height: 0.88;
      float: left;
      margin: 0.18rem 0.45rem 0 0;
      color: var(--color-red-civic);
    }
    .prose-content :is(h2, h3, h4) {
      font-family: var(--font-display);
      color: var(--color-ink);
    }
    .prose-content h2 {
      font-size: 1.7rem;
      font-weight: 700;
      margin: 3rem 0 1rem;
      padding-bottom: 0.4rem;
      border-bottom: 1px solid var(--color-rule);
      letter-spacing: -0.01em;
    }
    .prose-content h3 {
      font-size: 1.3rem;
      font-weight: 600;
      margin: 2.25rem 0 0.75rem;
    }
    .prose-content h4 {
      font-size: 1.1rem;
      font-weight: 600;
      font-style: italic;
      margin: 1.75rem 0 0.5rem;
      color: var(--color-ink-soft);
    }
    .prose-content p {
      margin: 0 0 1.2rem;
    }
    .prose-content ul, .prose-content ol {
      margin: 1rem 0 1.5rem 1.25rem;
      padding-left: 0.5rem;
    }
    .prose-content li {
      margin-bottom: 0.4rem;
    }
    .prose-content ul > li::marker {
      color: var(--color-red-civic);
      content: "§ ";
    }
    .prose-content ol > li::marker {
      color: var(--color-red-civic);
      font-family: var(--font-display);
      font-weight: 600;
    }
    .prose-content a {
      color: var(--color-red-civic);
      text-decoration: underline;
      text-underline-offset: 3px;
      text-decoration-thickness: 1px;
      text-decoration-color: rgba(139, 58, 31, 0.35);
    }
    .prose-content a:hover {
      color: var(--color-red-civic-deep);
      text-decoration-color: var(--color-red-civic);
    }
    .prose-content strong {
      color: var(--color-ink);
      font-weight: 700;
    }
    .prose-content em {
      font-style: italic;
      color: var(--color-ink);
    }
    .prose-content code {
      background: var(--color-paper-deep);
      padding: 0.1em 0.4em;
      border: 1px solid var(--color-rule);
      border-radius: 2px;
      font-family: var(--font-mono);
      font-size: 0.88em;
      color: var(--color-green-civic-deep);
    }
    .prose-content pre {
      background: var(--color-paper-deep);
      border: 1px solid var(--color-rule);
      padding: 1.1rem 1.25rem;
      margin: 1.75rem 0;
      overflow-x: auto;
      border-left: 3px solid var(--color-green-civic);
      font-size: 0.92rem;
      line-height: 1.55;
    }
    .prose-content pre code {
      background: transparent;
      padding: 0;
      border: 0;
      color: var(--color-ink);
      font-size: inherit;
    }
    .prose-content blockquote {
      border: 0;
      border-left: 3px solid var(--color-red-civic);
      padding: 0.2rem 0 0.2rem 1.25rem;
      margin: 1.75rem 0;
      color: var(--color-ink-soft);
      font-family: var(--font-display);
      font-style: italic;
      font-size: 1.08rem;
      line-height: 1.6;
    }
    .prose-content blockquote p {
      margin: 0 0 0.7rem;
    }
    .prose-content blockquote p:last-child { margin-bottom: 0; }
    .prose-content table {
      width: 100%;
      border-collapse: collapse;
      margin: 1.75rem 0;
      font-size: 0.95rem;
      font-family: var(--font-body);
    }
    .prose-content table caption {
      caption-side: top;
      text-align: left;
      font-family: var(--font-smallcaps);
      font-variant-caps: all-small-caps;
      letter-spacing: 0.14em;
      color: var(--color-green-civic);
      padding-bottom: 0.5rem;
    }
    .prose-content th, .prose-content td {
      padding: 0.65rem 0.9rem;
      border-bottom: 1px solid var(--color-rule);
      text-align: left;
      vertical-align: top;
    }
    .prose-content thead th {
      border-bottom: 2px solid var(--color-ink);
      font-family: var(--font-display);
      font-weight: 600;
      background: transparent;
    }
    .prose-content hr {
      border: 0;
      text-align: center;
      margin: 3rem 0;
      color: var(--color-rule);
      overflow: visible;
    }
    .prose-content hr::before {
      content: "§ § §";
      font-family: var(--font-display);
      letter-spacing: 0.5em;
      color: var(--color-rule);
    }
    .prose-content img {
      max-width: 100%;
      height: auto;
      padding: 0.5rem;
      background: var(--color-paper-deep);
      border: 1px solid var(--color-rule);
    }
  </style>
</BaseLayout>
