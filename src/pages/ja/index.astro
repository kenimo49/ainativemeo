---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => p.data.lang === 'ja')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const title = 'AI Native MEO — LLMO Framework のローカルビジネス実装';
const description = 'AI Native MEO は LLMO Framework をローカルビジネス領域に実装する方法論。AIに選ばれる店舗をつくるための、エンジニア視点の体系化。';
const ogUrl = 'https://ainativemeo.com/ja/';

const categoryLabel = (cat: string) => {
  return { framework: 'フレームワーク', engineering: 'エンジニアリング', comparison: '比較' }[cat] || cat;
};
---

<BaseLayout title={title} description={description} lang="ja" ogUrl={ogUrl}>
  <Nav lang="ja" />

  <main class="home">
    <section class="hero">
      <p class="eyebrow">Reference Implementation №1 · est. 2026</p>
      <h1 class="hero-title">
        <span class="hero-title-line-1">AI&nbsp;Native</span>
        <span class="hero-title-line-2">MEO</span>
      </h1>
      <div class="hero-rule" aria-hidden="true"></div>
      <p class="hero-lede">
        <a href="https://llmoframework.com/">LLMO Framework</a>
        をローカルビジネス領域に実装する最初のリファレンス実装。
        お客様が「検索」ではなく「AI に相談」して店を選ぶ時代の最適化を扱います。
      </p>
      <p class="hero-sub">
        AI 検索最適化の領域では AEO や GEO といった用語も使われますが、
        <strong>LLMO (Large Language Model Optimization)</strong>
        が最も精密なフレームワークとして急速に標準化が進んでいます。
        AI Native MEO はその LLMO のローカルビジネス領域への特化実装です。
      </p>
    </section>

    <div class="ornament">§ &nbsp; § &nbsp; §</div>

    <section class="definition">
      <p class="smallcaps def-label">定義</p>
      <h2 class="def-title">AI Native MEO とは</h2>
      <div class="def-body">
        <p>
          従来の MEO (Map Engine Optimization) は Google マップ順位を狙うものでした。
          AI Native MEO はその次のレイヤー — 顧客が ChatGPT / Gemini / Claude / Perplexity 等の生成 AI に自然言語で
          「近くで○○なお店ある?」と聞いたときに、
          <strong>AI が引用・推薦する側の店舗</strong>になるための運用を扱います。
        </p>
        <p>
          本サイトは MEO 代理店の視点ではなく、LLMO Framework 標準に準拠した
          <strong>エンジニア視点</strong>での体系化です。
        </p>
      </div>
    </section>

    {posts.length > 0 && (
      <section class="latest">
        <header class="latest-head">
          <p class="smallcaps">最新の収録記事</p>
          <a href="/ja/blog/" class="all-link">記事一覧 →</a>
        </header>
        <ol class="entry-list">
          {posts.map((post, idx) => (
            <li class="entry">
              <a href={`/ja/blog/${post.id.replace('ja/', '')}/`} class="entry-link">
                <span class="entry-no">{String(idx + 1).padStart(2, '0')}</span>
                <div class="entry-body">
                  <div class="entry-meta">
                    <span class={`entry-cat cat-${post.data.category}`}>{categoryLabel(post.data.category)}</span>
                    <time datetime={post.data.date.toISOString()}>{post.data.date.toISOString().split('T')[0]}</time>
                  </div>
                  <h3 class="entry-title">{post.data.title}</h3>
                  <p class="entry-desc">{post.data.description}</p>
                </div>
              </a>
            </li>
          ))}
        </ol>
      </section>
    )}

    <footer class="colophon">
      <div class="ornament">§ &nbsp; § &nbsp; §</div>
      <p>
        AI Native MEO は
        <a href="https://llmoframework.com/">LLMO Framework</a>
        の上に構築されています。
        <a href="https://kenimoto.dev/">井本 賢 (Ken Imoto)</a>
        の研究・出版エコシステムの一部です。
      </p>
    </footer>
  </main>
</BaseLayout>

<style>
  .home {
    max-width: 48rem;
    margin: 0 auto;
    padding: 3rem 1.5rem 4rem;
  }

  .hero { margin-bottom: 1.5rem; }
  .hero-title {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(3.5rem, 10vw, 6.5rem);
    line-height: 0.92;
    letter-spacing: -0.035em;
    margin: 0.6rem 0;
    color: var(--color-ink);
    display: flex;
    flex-direction: column;
  }
  .hero-title-line-1 { display: block; }
  .hero-title-line-2 {
    display: block;
    font-style: italic;
    font-weight: 400;
    color: var(--color-red-civic);
    margin-left: 2.5rem;
    margin-top: -0.4rem;
  }
  .hero-rule {
    border-bottom: 2px solid var(--color-ink);
    position: relative;
    margin: 1.2rem 0 1.5rem;
  }
  .hero-rule::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -5px;
    width: 100%;
    border-bottom: 1px solid var(--color-ink);
  }
  .hero-lede {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 1.25rem;
    line-height: 1.7;
    color: var(--color-ink-soft);
    margin: 0 0 1.25rem;
  }
  .hero-sub {
    font-family: var(--font-body);
    font-size: 1.02rem;
    line-height: 1.85;
    color: var(--color-ink-soft);
    margin: 0;
  }
  .hero-sub strong { color: var(--color-ink); font-weight: 700; }

  .ornament {
    text-align: center;
    color: var(--color-rule);
    font-family: var(--font-display);
    letter-spacing: 0.5em;
    font-size: 1rem;
    margin: 3rem 0;
  }

  .definition {
    display: grid;
    grid-template-columns: 8rem 1fr;
    column-gap: 2rem;
    row-gap: 0;
    margin: 0 0 1rem;
  }
  .def-label {
    grid-column: 1;
    grid-row: 1 / span 2;
    margin: 0.5rem 0 0;
    color: var(--color-green-civic);
    line-height: 1;
  }
  .def-title {
    grid-column: 2;
    grid-row: 1;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.75rem;
    line-height: 1.3;
    margin: 0 0 1rem;
    color: var(--color-ink);
  }
  .def-body {
    grid-column: 2;
    grid-row: 2;
  }
  .def-body p {
    font-family: var(--font-body);
    font-size: 1.02rem;
    line-height: 1.85;
    color: var(--color-ink-soft);
    margin: 0 0 1rem;
  }
  .def-body p:last-child { margin-bottom: 0; }
  .def-body strong { color: var(--color-ink); font-weight: 700; }
  .def-body a { color: var(--color-red-civic); }
  @media (max-width: 700px) {
    .definition { grid-template-columns: 1fr; column-gap: 0; row-gap: 0.75rem; }
    .def-label, .def-title, .def-body { grid-column: 1; grid-row: auto; }
  }

  .latest { margin: 0; }
  .latest-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.25rem;
    border-bottom: 1px solid var(--color-rule);
    padding-bottom: 0.5rem;
  }
  .latest-head .smallcaps { margin: 0; }
  .all-link {
    font-family: var(--font-smallcaps);
    font-variant-caps: all-small-caps;
    letter-spacing: 0.14em;
    color: var(--color-red-civic);
    text-decoration: none;
    font-size: 0.95rem;
  }
  .all-link:hover { text-decoration: underline; }

  .entry-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }
  .entry { border-bottom: 1px solid var(--color-rule); }
  .entry-link {
    display: grid;
    grid-template-columns: 3.5rem 1fr;
    gap: 1.25rem;
    padding: 1.25rem 0;
    text-decoration: none;
    color: var(--color-ink);
  }
  .entry-link:hover { text-decoration: none; }
  .entry-link:hover .entry-title { color: var(--color-red-civic); }
  .entry-no {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 2.4rem;
    color: var(--color-rule);
    line-height: 1;
    text-align: right;
    padding-top: 0.1rem;
  }
  .entry-meta {
    display: flex;
    align-items: baseline;
    gap: 0.9rem;
    font-family: var(--font-smallcaps);
    font-variant-caps: all-small-caps;
    letter-spacing: 0.14em;
    font-size: 0.9rem;
    margin-bottom: 0.4rem;
  }
  .entry-cat { color: var(--color-green-civic); font-weight: 500; }
  .entry-cat.cat-framework { color: var(--color-red-civic); }
  .entry-cat.cat-comparison { color: var(--color-ink-soft); }
  .entry-meta time {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-variant-caps: normal;
    letter-spacing: 0;
    font-size: 0.82rem;
  }
  .entry-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.35rem;
    line-height: 1.45;
    margin: 0 0 0.4rem;
    color: var(--color-ink);
    transition: color 0.15s ease;
  }
  .entry-desc {
    font-family: var(--font-body);
    font-size: 0.96rem;
    line-height: 1.75;
    color: var(--color-ink-soft);
    margin: 0;
  }

  .colophon { margin-top: 2rem; text-align: center; }
  .colophon p {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.95rem;
    color: var(--color-ink-soft);
    line-height: 1.7;
    margin: 0 auto;
    max-width: 32rem;
  }
  .colophon a { color: var(--color-red-civic); }
</style>
