---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => p.data.lang === 'ja')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const categoryLabel = (cat: string) => {
  return { framework: 'フレームワーク', engineering: 'エンジニアリング', comparison: '比較' }[cat] || cat;
};
---

<BaseLayout
  title="記事一覧 — AI Native MEO"
  description="AI Native MEO・LLMO Framework・JSON-LD・Googleビジネスプロフィール・各 AI エンジンのローカルデータ引用挙動についてのエンジニアリング記事。"
  lang="ja"
  ogUrl="https://ainativemeo.com/ja/blog/"
>
  <Nav lang="ja" />

  <main class="archive">
    <header class="archive-head">
      <p class="eyebrow">Archive · 全記事</p>
      <h1>記事一覧</h1>
      <div class="head-rule" aria-hidden="true"></div>
      <p class="archive-lede">
        AI Native MEO と LLMO Framework に関するフレームワーク・エンジニアリング・比較記事。
      </p>
    </header>

    <ol class="entry-list">
      {posts.map((post, idx) => (
        <li class="entry">
          <a href={`/ja/blog/${post.id.replace('ja/', '')}/`} class="entry-link">
            <span class="entry-no">{String(idx + 1).padStart(2, '0')}</span>
            <div class="entry-body">
              <div class="entry-meta">
                <span class={`entry-cat cat-${post.data.category}`}>{categoryLabel(post.data.category)}</span>
                <time datetime={post.data.date.toISOString()}>{post.data.date.toISOString().split('T')[0]}</time>
              </div>
              <h2 class="entry-title">{post.data.title}</h2>
              <p class="entry-desc">{post.data.description}</p>
            </div>
          </a>
        </li>
      ))}
    </ol>

    <div class="ornament" aria-hidden="true">§ &nbsp; § &nbsp; §</div>
  </main>
</BaseLayout>

<style>
  .archive {
    max-width: 48rem;
    margin: 0 auto;
    padding: 3rem 1.5rem 4rem;
  }
  .archive-head { margin-bottom: 2.5rem; }
  .archive-head h1 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.2rem, 5vw, 3.2rem);
    line-height: 1.1;
    letter-spacing: -0.025em;
    margin: 0.5rem 0 0;
    color: var(--color-ink);
  }
  .head-rule {
    border-bottom: 2px solid var(--color-ink);
    position: relative;
    margin: 1.25rem 0 1.25rem;
  }
  .head-rule::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -5px;
    width: 100%;
    border-bottom: 1px solid var(--color-ink);
  }
  .archive-lede {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--color-ink-soft);
    margin: 0;
    line-height: 1.7;
  }
  .entry-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }
  .entry { border-bottom: 1px solid var(--color-rule); }
  .entry:first-child { border-top: 1px solid var(--color-rule); }
  .entry-link {
    display: grid;
    grid-template-columns: 3.5rem 1fr;
    gap: 1.5rem;
    padding: 1.5rem 0;
    text-decoration: none;
    color: var(--color-ink);
  }
  .entry-link:hover { text-decoration: none; }
  .entry-link:hover .entry-title { color: var(--color-red-civic); }
  .entry-no {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: 2.6rem;
    color: var(--color-rule);
    line-height: 1;
    text-align: right;
    padding-top: 0.15rem;
  }
  .entry-meta {
    display: flex;
    align-items: baseline;
    gap: 0.9rem;
    font-family: var(--font-smallcaps);
    font-variant-caps: all-small-caps;
    letter-spacing: 0.14em;
    font-size: 0.92rem;
    margin-bottom: 0.45rem;
  }
  .entry-cat { color: var(--color-green-civic); font-weight: 500; }
  .entry-cat.cat-framework { color: var(--color-red-civic); }
  .entry-cat.cat-comparison { color: var(--color-ink-soft); }
  .entry-meta time {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-variant-caps: normal;
    letter-spacing: 0;
    font-size: 0.83rem;
  }
  .entry-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.5rem;
    line-height: 1.4;
    margin: 0 0 0.5rem;
    color: var(--color-ink);
    transition: color 0.15s ease;
  }
  .entry-desc {
    font-family: var(--font-body);
    font-size: 0.98rem;
    line-height: 1.75;
    color: var(--color-ink-soft);
    margin: 0;
  }
  .ornament {
    text-align: center;
    color: var(--color-rule);
    font-family: var(--font-display);
    letter-spacing: 0.5em;
    font-size: 1rem;
    margin: 3rem 0 0;
  }
</style>
